DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL — si POSTGRES_DB est défini, Django utilise Postgres (sinon SQLite / db.sqlite3).
# Créez la base avant : createdb kokozito  (ou via pgAdmin)
# POSTGRES_DB=kokozito
# POSTGRES_USER=kokozito
# POSTGRES_PASSWORD=votre_mot_de_passe
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
