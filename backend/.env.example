DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Origines CORS autorisées (virgules), en plus de localhost:4200. Ex. prod :
# DJANGO_CORS_ALLOWED_ORIGINS=https://votre-front.pages.dev,https://www.votredomaine.com

# Render / Heroku : URL Postgres complète (prioritaire sur POSTGRES_*).
# DATABASE_URL=postgres://user:pass@host:5432/dbname

# Forcer SSL côté client Postgres si besoin (0 ou 1).
# DATABASE_SSL_REQUIRE=0

# Servir /media/ via Django en prod (démo seulement ; idéal = S3 / R2).
# DJANGO_SERVE_MEDIA=0

# PostgreSQL manuel — si DATABASE_URL absent et POSTGRES_DB défini.
# POSTGRES_DB=kokozito
# POSTGRES_USER=kokozito
# POSTGRES_PASSWORD=votre_mot_de_passe
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
